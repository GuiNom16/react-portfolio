{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "ES2022"
        ],
        "module": "CommonJS",
        "moduleResolution": "node",
        "skipLibCheck": true,
        "strict": true,
        "esModuleInterop": true,
        "outDir": "dist/api"
    },
    "include": [
        "api/**/*.ts",
        "scripts/**/*.ts"
    ]
}